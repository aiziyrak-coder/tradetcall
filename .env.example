# Server
PORT=3070
NODE_ENV=production
SESSION_SECRET=change-this-to-a-long-random-string
DATA_DIR=./data
DJANGO_AUTH_URL=http://127.0.0.1:8070
FRONTEND_ORIGIN=https://trade.ziyrak.org
CORS_ORIGINS=https://trade.ziyrak.org

# Frontend build (production)
# VITE_API_BASE=https://tradeapi.ziyrak.org

# AI sessiyasi (ms) — AI START dan keyin avto-stop (default 30 daqiqa)
# AI_SESSION_MS=1800000

# Yangilik tarjimasi limiti
# MYMEMORY_EMAIL=

# TradingView narx — chart broker bilan bir xil symbol (FOREX.com chart = FOREXCOM:XAUUSD)
TRADINGVIEW_SYMBOL=FOREXCOM:XAUUSD

# DeepSeek AI (YANGI PROGNOZ) — platform.deepseek.com → API Keys
# DEEPSEEK_API_KEY=sk-...
