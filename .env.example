# Server (dev: 3080 — 3000 band bo'lsa ZiyrakAI)
PORT=3080
NODE_ENV=development
SESSION_SECRET=change-this-to-a-long-random-string
DJANGO_SECRET_KEY=change-django-secret-in-production
DATA_DIR=./data
DJANGO_AUTH_URL=http://127.0.0.1:8001
FRONTEND_ORIGIN=http://127.0.0.1:5173
CORS_ORIGINS=http://127.0.0.1:5173

# Production (trade.ziyrak.org)
# PORT=3070
# NODE_ENV=production
# DJANGO_AUTH_URL=http://127.0.0.1:8070
# FRONTEND_ORIGIN=https://trade.ziyrak.org
# CORS_ORIGINS=https://trade.ziyrak.org
# COOKIE_DOMAIN=.ziyrak.org
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,tradeapi.ziyrak.org
# DJANGO_PUBLIC_ADMIN_URL=https://tradeapi.ziyrak.org/admin/

# Frontend build (production)
# VITE_API_BASE=https://tradeapi.ziyrak.org

# TradingView narx (asosiy real-time — kalitsiz adapter)
TRADINGVIEW_SYMBOL=FOREXCOM:XAUUSD
# TRADINGVIEW_STALE_MS=12000

# Ixtiyoriy: Finnhub WebSocket (bepul tarif, 60 req/min + WS)
# Ro'yxat: https://finnhub.io/register  — kalitni HECH QACHON frontendga qo'ymang
# FINNHUB_API_KEY=
# FINNHUB_SYMBOL=OANDA:XAU_USD
# FINNHUB_STALE_MS=15000

# Ixtiyoriy: NewsAPI.org (developer — ko'pincha faqat localhost)
# Ro'yxat: https://newsapi.org/register
# NEWS_API_KEY=

# OpenAI AI (YANGI PROGNOZ) — platform.openai.com → API Keys
# OPENAI_API_KEY=sk-proj-...
