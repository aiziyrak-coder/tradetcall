{
  "name": "xauusd-trade",
  "version": "2.0.0",
  "description": "XAUUSD Oltin Trader — Web terminal",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:django\" \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "vite --config web/vite.config.ts",
    "dev:server": "tsx watch server/index.ts",
    "dev:django": "node scripts/run-django.mjs",
    "setup:django": "node scripts/setup-django.mjs",
    "build:server": "node scripts/build-server.mjs",
    "build:web": "vite build --config web/vite.config.ts",
    "build": "npm run build:web && npm run build:server",
    "start": "cross-env NODE_ENV=production node dist-server/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.audit.json",
    "audit": "node scripts/audit.mjs",
    "verify:ai": "tsx scripts/verify-ai-parse.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "rss-parser": "^3.13.0",
    "tradingview-api-adapter": "^2.0.0",
    "uuid": "^11.0.3",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.24.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ssh2": "^1.17.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
